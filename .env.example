# Sao chép file này thành ".env" rồi điền giá trị thật — KHÔNG commit ".env"

# Bắt buộc — khoá gọi Groq LLM API (sinh câu trả lời)
GROQ_API_KEY=

# Bắt buộc — khoá Google AI Studio cho Gemini embeddings (miễn phí, lấy tại
# https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Bắt buộc cho production — khoá ký session cookie (itsdangerous/SessionMiddleware)
# Sinh giá trị ngẫu nhiên đủ mạnh, vd: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Tuỳ chọn — ghi đè đường dẫn mặc định nếu cần
# DB_PATH=./data/app.db
# CHROMA_DIR=./chroma_db
# CHROMA_COLLECTION=giao_trinh_c

# Tuỳ chọn — đổi model embedding/LLM nếu cần
# EMBEDDING_MODEL=models/gemini-embedding-001
# GROQ_MODEL=llama-3.3-70b-versatile

# Tuỳ chọn (production trên VPS có HTTPS) — đặt true để cookie session chỉ gửi qua HTTPS
# SESSION_HTTPS_ONLY=true
